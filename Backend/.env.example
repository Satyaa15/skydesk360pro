# Runtime
ENVIRONMENT=development
SQL_ECHO=false

# Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/skydesk_db

# Auth
SECRET_KEY=replace_with_a_strong_secret_at_least_32_characters
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# CORS (comma-separated)
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Email — SMTP credentials (required for booking confirmation emails)
# Google Workspace / Gmail:  MAIL_SERVER=smtp.gmail.com  MAIL_PORT=587
# Zoho Mail:                 MAIL_SERVER=smtp.zoho.in    MAIL_PORT=587
# Other providers:           check your mail provider's SMTP settings
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=info@skydesk360.com
MAIL_PASSWORD=your_app_password_here
MAIL_FROM=info@skydesk360.com
MAIL_FROM_NAME=SkyDesk360

# Admin bootstrap (required in production)
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=change_this_strong_password

# Razorpay (https://dashboard.razorpay.com/app/keys)
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret
